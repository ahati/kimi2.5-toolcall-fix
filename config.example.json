{
  "providers": [
    {
      "name": "kimi-k2",
      "endpoints": {
        "openai": "https://llm.chutes.ai/v1/chat/completions",
        "anthropic": "https://llm.chutes.ai/v1/messages"
      },
      "default": "openai",
      "envApiKey": "CHUTES_API_KEY"
    },
    {
      "name": "alibaba-coding-plan",
      "type": "anthropic",
      "base_url": "https://coding-intl.dashscope.aliyuncs.com/apps/anthropic/v1/messages",
      "envApiKey": "ALIBABA_ANTHROPIC_API_KEY"
    }
  ],
  "models": {
    "kimi-k2.5": {
      "provider": "kimi-k2",
      "model": "moonshotai/Kimi-K2.5-TEE",
      "type": "auto",
      "kimi_tool_call_transform": true
    },
    "claude-3-opus": {
      "provider": "alibaba-coding-plan",
      "model": "claude-3-opus-20240229",
      "kimi_tool_call_transform": false
    }
  },
  "fallback": {
    "enabled": true,
    "provider": "kimi-k2",
    "model": "{model}",
    "type": "auto",
    "kimi_tool_call_transform": true
  }
}