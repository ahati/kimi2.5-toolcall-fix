{
  "providers": [
    {
      "name": "chutes",
      "type": "openai",
      "base_url": "https://llm.chutes.ai/v1/chat/completions",
      "envApiKey": "CHUTES_API_KEY"
    },
    {
      "name": "minimax_openai",
      "type": "openai",
      "base_url": "https://api.minimax.io/v1/chat/completions",
      "envApiKey": "MINIMAX_IO_API_KEY"
    },
    {
      "name": "minimax_anthropic",
      "type": "anthropic",
      "base_url": "https://api.minimax.io/anthropic/v1/messages",
      "envApiKey": "MINIMAX_IO_API_KEY"
    },
    {
      "name": "alibaba_anthropic",
      "type": "anthropic",
      "base_url": "https://coding-intl.dashscope.aliyuncs.com/apps/anthropic/v1/messages",
      "envApiKey": "ALIBABA_API_KEY"
    },
    {
      "name": "alibaba_openai",
      "type": "openai",
      "base_url": "https://coding-intl.dashscope.aliyuncs.com/v1/chat/completions",
      "envApiKey": "ALIBABA_API_KEY"
    }
  ],
  "models": {
    "moonshotai/Kimi-K2.5-TEE": {
      "provider": "chutes",
      "model": "moonshotai/Kimi-K2.5-TEE",
      "tool_call_transform": true
    },
    "zai-org/GLM-5-TEE": {
      "provider": "chutes",
      "model": "zai-org/GLM-5-TEE",
      "tool_call_transform": false
    },
    "kimi-k2.5": {
      "provider": "alibaba_anthropic",
      "model": "kimi-k2.5",
      "tool_call_transform": true
    },
    "gpt-5.4": {
      "provider": "alibaba_anthropic",
      "model": "glm-5",
      "tool_call_transform": false
    },
    "gpt-5.3-codex": {
      "provider": "alibaba_anthropic",
      "model": "glm-5",
      "tool_call_transform": false
    },
    "gpt-5.1-codex-mini": {
      "provider": "minimax_openai",
      "model": "MiniMax-M2.7",
      "tool_call_transform": false
    },
    "gpt-5-mini": {
      "provider": "minimax_openai",
      "model": "MiniMax-M2.7",
      "tool_call_transform": false
    },
    "MiniMax-M2.7": {
      "provider": "minimax_anthropic",
      "model": "MiniMax-M2.7",
      "tool_call_transform": false
    },
    "qwen3-max": {
      "provider": "alibaba_openai",
      "model": "qwen3-max-2026-01-23",
      "tool_call_transform": false
    }
  },
  "fallback": {
    "enabled": true,
    "provider": "alibaba_openai",
    "model": "{model}",
    "tool_call_transform": false
  }
}