{
  "providers": [
    {
      "name": "chutes",
      "endpoints": {
        "openai": "https://llm.chutes.ai/v1/chat/completions",
        "anthropic": "https://claude.chutes.ai/v1/messages"
      },
      "default": "openai",
      "envApiKey": "CHUTES_API_KEY"
    },
    {
      "name": "minimax",
      "endpoints": {
        "openai": "https://api.minimax.io/v1/chat/completions",
        "anthropic": "https://api.minimax.io/anthropic/v1/messages"
      },
      "default": "openai",
      "envApiKey": "MINIMAX_IO_API_KEY"
    },
    {
      "name": "alibaba",
      "endpoints": {
        "openai": "https://coding-intl.dashscope.aliyuncs.com/v1/chat/completions",
        "anthropic": "https://coding-intl.dashscope.aliyuncs.com/apps/anthropic/v1/messages"
      },
      "default": "openai",
      "envApiKey": "ALIBABA_API_KEY"
    }
  ],
  "models": {
    "moonshotai/Kimi-K2.5-TEE": {
      "provider": "chutes",
      "model": "moonshotai/Kimi-K2.5-TEE",
      "type": "auto",
      "kimi_tool_call_transform": true
    },
    "glm-5": {
      "provider": "alibaba",
      "model": "glm-5",
      "type": "auto",
      "glm5_tool_call_transform": true
    },
    "kimi-k2.5": {
      "provider": "alibaba",
      "model": "kimi-k2.5",
      "type": "anthropic",
      "kimi_tool_call_transform": true
    },
    "gpt-5.4": {
      "provider": "alibaba",
      "model": "glm-5",
      "kimi_tool_call_transform": false
    },
    "gpt-5.3-codex": {
      "provider": "alibaba",
      "model": "glm-5",
      "glm5_tool_call_transform": true
    },
    "gpt-5.1-codex-mini": {
      "provider": "minimax",
      "model": "MiniMax-M2.7",
      "type": "auto",
      "kimi_tool_call_transform": false,
      "reasoning_split": true
    },
    "gpt-5-mini": {
      "provider": "minimax",
      "model": "MiniMax-M2.7",
      "type": "auto",
      "kimi_tool_call_transform": false,
      "reasoning_split": true
    },
    "MiniMax-M2.7": {
      "provider": "minimax",
      "model": "MiniMax-M2.7",
      "type": "auto",
      "kimi_tool_call_transform": false,
      "reasoning_split": true
    },
    "qwen3-max": {
      "provider": "alibaba",
      "model": "qwen3-max-2026-01-23",
      "type": "auto",
      "kimi_tool_call_transform": false
    }
  },
  "fallback": {
    "enabled": true,
    "provider": "alibaba",
    "model": "{model}",
    "type": "auto",
    "kimi_tool_call_transform": false
  },
  "summarizer": {
    "enabled": true,
    "mode": "local",
    "local": {
      "model_path": "../temporary/summarizer/models/Qwen3.5-0.8B-Q4_K_M.gguf",
      "context_size": 2048,
      "threads": 4,
      "max_summary_tokens": 50
    }
  }
}